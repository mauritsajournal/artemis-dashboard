---
import Layout from '../../layouts/Layout.astro';
import GlowPanel from '../../components/GlowPanel.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import StatusBadge from '../../components/StatusBadge.astro';

// Load config
let config: Record<string, unknown> = {};
try {
  const mod = await import('../../../data/config.json');
  config = mod.default;
} catch { /* not yet available */ }

// Load weather data
let weather: Record<string, unknown> = {};
let weatherAge = 'Unknown';
try {
  const mod = await import('../../../data/weather.json');
  weather = mod.default;
  const fetched = new Date(weather.fetchedAt as string);
  const diffMs = Date.now() - fetched.getTime();
  const hours = Math.floor(diffMs / 3600000);
  const mins = Math.floor((diffMs % 3600000) / 60000);
  weatherAge = hours > 0 ? `${hours}h ${mins}m ago` : `${mins}m ago`;
} catch { /* not yet available */ }

// Load news data
let newsCount = 0;
let newsAge = 'Unknown';
try {
  const mod = await import('../../../data/news.json');
  newsCount = (mod.default as { articles: unknown[] }).articles?.length ?? 0;
  const fetched = new Date((mod.default as { fetchedAt: string }).fetchedAt);
  const diffMs = Date.now() - fetched.getTime();
  const hours = Math.floor(diffMs / 3600000);
  const mins = Math.floor((diffMs % 3600000) / 60000);
  newsAge = hours > 0 ? `${hours}h ${mins}m ago` : `${mins}m ago`;
} catch { /* not yet available */ }
---

<Layout title="System Status — Artemis II">
  <div class="text-center mb-8 animate-fade-in-up">
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-wider text-white">
      SYSTEM <span class="text-mission-green">STATUS</span>
    </h1>
    <p class="text-white/30 text-sm mt-2 font-display tracking-wider">DATA HEALTH + CONFIGURATION</p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Data sources -->
    <GlowPanel class="animate-fade-in-up stagger-1">
      <SectionHeader title="Data Sources" accent="cyan" />
      <div class="space-y-3">
        <div class="flex items-center justify-between p-3 glass-panel-sm">
          <div>
            <div class="text-sm text-white/70 font-medium">Weather Data</div>
            <div class="text-xs text-white/30">Open-Meteo + NOAA SWPC</div>
          </div>
          <div class="text-right">
            <StatusBadge status={weather.fetchedAt ? 'go' : 'nogo'} label={weather.fetchedAt ? 'LIVE' : 'OFFLINE'} size="sm" />
            <div class="text-[10px] text-white/20 mt-1">{weatherAge}</div>
          </div>
        </div>
        <div class="flex items-center justify-between p-3 glass-panel-sm">
          <div>
            <div class="text-sm text-white/70 font-medium">News Feed</div>
            <div class="text-xs text-white/30">5 RSS sources</div>
          </div>
          <div class="text-right">
            <StatusBadge status={newsCount > 0 ? 'go' : 'nogo'} label={newsCount > 0 ? `${newsCount} ARTICLES` : 'OFFLINE'} size="sm" />
            <div class="text-[10px] text-white/20 mt-1">{newsAge}</div>
          </div>
        </div>
        <div class="flex items-center justify-between p-3 glass-panel-sm">
          <div>
            <div class="text-sm text-white/70 font-medium">Mission Config</div>
            <div class="text-xs text-white/30">data/config.json</div>
          </div>
          <StatusBadge status={Object.keys(config).length > 0 ? 'go' : 'nogo'} label="LOADED" size="sm" />
        </div>
      </div>
    </GlowPanel>

    <!-- Configuration -->
    <GlowPanel class="animate-fade-in-up stagger-2">
      <SectionHeader title="Configuration" accent="orange" />
      <div class="space-y-2 text-sm font-mono">
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">missionPhase</span>
          <span class="text-nasa-orange font-semibold">{config.missionPhase ?? 'unknown'}</span>
        </div>
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">launchDate</span>
          <span class="text-white/70">{config.launchDate ?? 'not set'}</span>
        </div>
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">missionDay</span>
          <span class="text-white/70">{config.missionDay ?? 0}</span>
        </div>
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">holdMessage</span>
          <span class="text-white/70">{config.holdMessage ?? 'null'}</span>
        </div>
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">scrubMessage</span>
          <span class="text-white/70">{config.scrubMessage ?? 'null'}</span>
        </div>
        <div class="flex justify-between p-2 glass-panel-sm">
          <span class="text-white/40">nasaTvVideoId</span>
          <span class="text-white/70">{config.nasaTvVideoId ?? 'not set'}</span>
        </div>
      </div>
    </GlowPanel>
  </div>
</Layout>
