---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Launch Day — Artemis II">
  <div class="text-center mb-8 animate-fade-in-up">
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-wider text-white">
      LAUNCH <span class="text-nasa-orange text-glow-orange">DAY</span>
    </h1>
    <p class="text-white/30 text-sm mt-2 font-display tracking-wider">PRE-LAUNCH TIMELINE + ASCENT EVENTS</p>
  </div>
  <div class="text-center py-20 text-white/20 font-display tracking-widest">
    LAUNCH TIMELINE LOADING...
  </div>
</Layout>
