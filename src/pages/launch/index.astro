---
import Layout from '../../layouts/Layout.astro';
import GlowPanel from '../../components/GlowPanel.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PreLaunchTimeline from '../../components/PreLaunchTimeline.svelte';
import LaunchEventTracker from '../../components/LaunchEventTracker.svelte';

// Load config
let config: any = {};
try {
  const mod = await import('../../../data/config.json');
  config = mod.default;
} catch {}

const launchDate = config.launchDate ?? '2026-04-01T18:24:00-04:00';
const configCompletedEvents: string[] = config.completedLaunchEvents ?? [];
---

<Layout title="Launch Day — Artemis II">
  <div class="text-center mb-8 animate-fade-in-up">
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-wider text-white">
      LAUNCH <span class="text-nasa-orange text-glow-orange">DAY</span>
    </h1>
    <p class="text-white/30 text-sm mt-2 font-display tracking-wider">PRE-LAUNCH COUNTDOWN + ASCENT EVENTS</p>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <GlowPanel class="animate-fade-in-up">
      <SectionHeader title="Pre-Launch Timeline" subtitle="Countdown milestones to liftoff" accent="orange" />
      <PreLaunchTimeline client:load launchDate={launchDate} />
    </GlowPanel>

    <GlowPanel class="animate-fade-in-up stagger-2">
      <SectionHeader title="Launch & Ascent" subtitle="Liftoff through Translunar Injection" accent="orange" />
      <LaunchEventTracker client:load launchDate={launchDate} configCompletedEvents={configCompletedEvents} />
    </GlowPanel>
  </div>
</Layout>
