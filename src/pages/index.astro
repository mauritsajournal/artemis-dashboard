---
import Layout from '../layouts/Layout.astro';
import GlowPanel from '../components/GlowPanel.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CountdownTimer from '../components/CountdownTimer.svelte';
import WeatherPanel from '../components/WeatherPanel.astro';
import GoNoGoPanel from '../components/GoNoGoPanel.astro';
import HistoricalContext from '../components/HistoricalContext.astro';
// Load config
let config = {
  launchDate: '2025-09-01T12:00:00-04:00',
  missionPhase: 'prelaunch',
  backupWindows: [] as string[],
  holdMessage: null as string | null,
  scrubMessage: null as string | null,
};

try {
  const mod = await import('../../data/config.json');
  config = { ...config, ...mod.default };
} catch {
  // Config not available
}
---

<Layout title="Artemis II — Countdown">
  <!-- Hold/Scrub message -->
  {config.holdMessage && (
    <div class="glass-panel border-status-concern/30 p-4 mb-8 text-center animate-fade-in-up">
      <div class="flex items-center justify-center gap-2 mb-1">
        <div class="w-2 h-2 rounded-full bg-status-concern animate-pulse"></div>
        <span class="font-display text-sm tracking-wider font-bold text-status-concern">HOLD</span>
      </div>
      <p class="text-white/60 text-sm">{config.holdMessage}</p>
    </div>
  )}

  {config.scrubMessage && (
    <div class="glass-panel border-status-nogo/30 p-4 mb-8 text-center animate-fade-in-up">
      <div class="flex items-center justify-center gap-2 mb-1">
        <div class="w-2 h-2 rounded-full bg-status-nogo animate-pulse"></div>
        <span class="font-display text-sm tracking-wider font-bold text-status-nogo">SCRUB</span>
      </div>
      <p class="text-white/60 text-sm">{config.scrubMessage}</p>
    </div>
  )}

  <!-- Hero section: Mission title -->
  <div class="text-center mb-6 animate-fade-in-up">
    <div class="inline-block mb-4">
      <div class="font-display text-xs tracking-[0.3em] text-white/40 mb-2">NASA</div>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold tracking-wider text-white">
        ARTEMIS <span class="text-nasa-orange text-glow-orange">II</span>
      </h1>
      <div class="separator-glow mt-3 mb-3"></div>
      <p class="font-display text-xs sm:text-sm tracking-[0.2em] text-white/50">
        FIRST CREWED LUNAR MISSION IN OVER 50 YEARS
      </p>
    </div>
  </div>

  <!-- Countdown timer (Svelte island) -->
  <GlowPanel glow="orange" padding="lg" class="mb-10 animate-fade-in-up stagger-2">
    <CountdownTimer
      client:load
      launchDate={config.launchDate}
      missionPhase={config.missionPhase}
      backupWindows={config.backupWindows}
    />
  </GlowPanel>

  <!-- Quick stats grid -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-3 sm:gap-4 mb-10">
    <div class="glass-panel-sm p-4 text-center animate-fade-in-up stagger-3">
      <div class="section-label mb-1">CREW</div>
      <div class="font-display text-3xl font-bold text-white">4</div>
      <div class="text-xs text-white/40 mt-1">Astronauts</div>
    </div>
    <div class="glass-panel-sm p-4 text-center animate-fade-in-up stagger-4">
      <div class="section-label mb-1">DURATION</div>
      <div class="font-display text-3xl font-bold text-white">~10</div>
      <div class="text-xs text-white/40 mt-1">Days</div>
    </div>
    <div class="glass-panel-sm p-4 text-center animate-fade-in-up stagger-5">
      <div class="section-label mb-1">DISTANCE</div>
      <div class="font-display text-3xl font-bold text-white">~392K</div>
      <div class="text-xs text-white/40 mt-1">km from Earth</div>
    </div>
    <div class="glass-panel-sm p-4 text-center animate-fade-in-up stagger-6">
      <div class="section-label mb-1">TO THE MOON</div>
      <div class="font-display text-3xl font-bold text-mission-cyan" id="moon-distance">384K</div>
      <div class="text-xs text-white/40 mt-1">km remaining</div>
    </div>
    <div class="glass-panel-sm p-4 text-center animate-fade-in-up stagger-7 col-span-2 md:col-span-1">
      <div class="section-label mb-1">SINCE APOLLO 17</div>
      <div class="font-display text-3xl font-bold text-nasa-orange" id="years-since"></div>
      <div class="text-xs text-white/40 mt-1">Years</div>
    </div>
  </div>

  <!-- Weather + GO/NO-GO -->
  <div class="grid md:grid-cols-2 gap-6 mb-10">
    <WeatherPanel />
    <GoNoGoPanel />
  </div>

  <!-- Mission summary -->
  <div class="grid md:grid-cols-2 gap-6 animate-fade-in-up stagger-7">
    <GlowPanel>
      <SectionHeader title="The Mission" accent="cyan" />
      <p class="text-white/70 text-sm leading-relaxed mb-4">
        Artemis II will send four astronauts around the Moon aboard the Orion spacecraft, launched by the Space Launch System (SLS) rocket. It will be the first crewed mission to venture beyond low-Earth orbit since Apollo 17 in December 1972.
      </p>
      <p class="text-white/70 text-sm leading-relaxed">
        The ~10 day mission will fly a free-return trajectory, swinging around the far side of the Moon at an altitude of approximately 7,600 km above the lunar surface, reaching a maximum distance of ~392,000 km from Earth.
      </p>
    </GlowPanel>

    <GlowPanel>
      <SectionHeader title="Historic Firsts" accent="orange" />
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-nasa-orange mt-2 shrink-0"></div>
          <div>
            <div class="text-sm text-white/70 font-medium">First woman beyond low-Earth orbit</div>
            <div class="text-xs text-white/50">Christina Koch</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-nasa-orange mt-2 shrink-0"></div>
          <div>
            <div class="text-sm text-white/70 font-medium">First person of color beyond low-Earth orbit</div>
            <div class="text-xs text-white/50">Victor Glover</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-nasa-orange mt-2 shrink-0"></div>
          <div>
            <div class="text-sm text-white/70 font-medium">First non-American on a lunar mission</div>
            <div class="text-xs text-white/50">Jeremy Hansen (CSA, Canada)</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-nasa-orange mt-2 shrink-0"></div>
          <div>
            <div class="text-sm text-white/70 font-medium">First humans beyond LEO since 1972</div>
            <div class="text-xs text-white/50">53+ years since Apollo 17</div>
          </div>
        </div>
      </div>
    </GlowPanel>
  </div>

  <!-- Live Stream -->
  <GlowPanel glow="orange" class="mt-10 mb-10 animate-fade-in-up stagger-8">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
      <span class="font-display text-sm tracking-[0.15em] font-bold text-white/80">NASA TV — LIVE STREAM</span>
    </div>
    <div class="aspect-video rounded-lg overflow-hidden bg-black/50 border border-white/5">
      <iframe
        src={`https://www.youtube.com/embed/${config.nasaTvVideoId ?? 'NaJklsJonD4'}?autoplay=1&mute=1`}
        title="NASA TV Live Stream"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>
  </GlowPanel>

  <!-- Historical context -->
  <div class="mt-6">
    <HistoricalContext />
  </div>
</Layout>

<script is:inline>
  function updateYearsSince() {
    const el = document.getElementById('years-since');
    if (el) {
      const apollo17 = new Date('1972-12-19T00:00:00Z');
      const diff = Date.now() - apollo17.getTime();
      const years = (diff / (365.25 * 24 * 3600 * 1000)).toFixed(1);
      el.textContent = years;
    }
  }

  function updateMoonDistance() {
    const el = document.getElementById('moon-distance');
    if (!el) return;

    // Waypoints from trajectory data (outbound + return)
    var waypoints = [
      { day: 0, dist: 0 }, { day: 1, dist: 50000 }, { day: 2, dist: 120000 },
      { day: 3, dist: 200000 }, { day: 4, dist: 300000 }, { day: 5, dist: 370000 },
      { day: 6, dist: 392000 }, { day: 7, dist: 350000 }, { day: 8, dist: 250000 },
      { day: 9, dist: 130000 }, { day: 10, dist: 0 }
    ];
    var MOON_DIST = 384400;
    var missionDay = 0; // prelaunch default

    // Interpolate distance from earth based on mission day
    var distFromEarth = 0;
    if (missionDay > 0 && missionDay < 10) {
      var prev = waypoints[0];
      for (var i = 0; i < waypoints.length; i++) {
        if (waypoints[i].day <= missionDay) prev = waypoints[i];
      }
      var next = null;
      for (var j = 0; j < waypoints.length; j++) {
        if (waypoints[j].day > missionDay) { next = waypoints[j]; break; }
      }
      if (prev && next) {
        var t = (missionDay - prev.day) / (next.day - prev.day);
        distFromEarth = prev.dist + t * (next.dist - prev.dist);
      } else {
        distFromEarth = prev.dist;
      }
    }

    // For outbound (day <= 6): show distance remaining to Moon
    // For return (day > 6): show distance to Earth
    var remaining;
    var label = el.parentElement ? el.parentElement.querySelector('.section-label') : null;
    var subtitle = el.nextElementSibling;

    if (missionDay <= 6) {
      remaining = MOON_DIST - distFromEarth;
      if (label) label.textContent = 'TO THE MOON';
      if (subtitle) subtitle.textContent = 'km remaining';
    } else {
      remaining = distFromEarth;
      if (label) label.textContent = 'TO EARTH';
      if (subtitle) subtitle.textContent = 'km remaining';
    }

    if (remaining < 0) remaining = 0;
    if (remaining >= 1000) {
      el.textContent = Math.round(remaining / 1000) + 'K';
    } else {
      el.textContent = Math.round(remaining).toString();
    }
  }

  updateYearsSince();
  updateMoonDistance();
  document.addEventListener('astro:after-swap', function() { updateYearsSince(); updateMoonDistance(); });
</script>
