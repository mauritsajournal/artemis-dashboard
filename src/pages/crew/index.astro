---
import Layout from '../../layouts/Layout.astro';
import GlowPanel from '../../components/GlowPanel.astro';
import SectionHeader from '../../components/SectionHeader.astro';

// Load crew data
let crew: any[] = [];
try {
  const mod = await import('../../../data/crew.json');
  crew = mod.default;
} catch { /* not available */ }
---

<Layout title="Crew — Artemis II">
  <div class="text-center mb-10 animate-fade-in-up">
    <div class="font-display text-xs tracking-[0.3em] text-white/20 mb-2">MEET THE</div>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-wider text-white">
      ARTEMIS II <span class="text-mission-amber">CREW</span>
    </h1>
    <div class="separator-glow mt-4 mb-4 max-w-sm mx-auto"></div>
    <p class="text-white/30 text-sm max-w-xl mx-auto">
      Four astronauts making history as the first humans to venture beyond low-Earth orbit in over 50 years.
    </p>
  </div>

  <!-- Crew grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
    {crew.map((member, i) => (
      <div class={`animate-fade-in-up stagger-${i + 1}`}>
        <div class="glass-panel overflow-hidden card-interactive group h-full">
          {/* Avatar area */}
          <div class="relative h-48 flex items-center justify-center overflow-hidden"
               style={`background: linear-gradient(135deg, ${member.color}15, ${member.color}05)`}>
            {/* Large initials as avatar */}
            <div class="font-display text-7xl font-bold tracking-wider opacity-20 select-none"
                 style={`color: ${member.color}`}>
              {member.initials}
            </div>
            {/* Agency badge */}
            <div class="absolute top-3 right-3 glass-panel-sm px-2.5 py-1">
              <span class="font-display text-[10px] tracking-wider font-bold"
                    style={`color: ${member.color}`}>{member.agency}</span>
            </div>
            {/* Flight number */}
            <div class="absolute top-3 left-3 text-[10px] text-white/20 font-display tracking-wider">
              FLIGHT #{member.flightNumber}
            </div>
            {/* Bottom gradient */}
            <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-space-base to-transparent"></div>
          </div>

          {/* Content */}
          <div class="p-5 -mt-2 relative">
            <div class="font-display text-lg font-bold tracking-wider text-white mb-0.5">{member.name}</div>
            <div class="text-xs text-white/40 mb-1 font-display tracking-wider">{member.role}</div>
            {member.rank && <div class="text-[10px] text-white/20 mb-3">{member.rank} | {member.agencyFull}</div>}
            {!member.rank && <div class="text-[10px] text-white/20 mb-3">{member.agencyFull}</div>}

            {/* Bio */}
            <p class="text-xs text-white/35 leading-relaxed mb-4">{member.bio}</p>

            {/* First badge — prominent */}
            <div class="p-3 rounded-lg border border-dashed"
                 style={`border-color: ${member.color}40; background: ${member.color}08`}>
              <div class="flex items-start gap-2">
                <div class="shrink-0 mt-0.5">
                  <svg class="w-4 h-4" style={`color: ${member.color}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <div class="text-[10px] font-display tracking-[0.15em] font-semibold mb-0.5"
                       style={`color: ${member.color}`}>HISTORIC FIRST</div>
                  <div class="text-xs text-white/50 leading-relaxed">{member.firstBadge}</div>
                </div>
              </div>
            </div>

            {/* Social link */}
            {member.twitter && (
              <a href={`https://x.com/${member.twitter}`} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1.5 mt-3 text-[10px] text-white/20 hover:text-white/40 no-underline font-display tracking-wider transition-colors">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                @{member.twitter}
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* Collective achievement */}
  <GlowPanel glow="orange" class="text-center animate-fade-in-up stagger-5">
    <div class="py-4">
      <div class="font-display text-xs tracking-[0.3em] text-nasa-orange/50 mb-3">TOGETHER, THEY WILL BE</div>
      <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-wider text-white mb-3">
        THE FIRST HUMANS BEYOND LEO<br/>
        <span class="text-nasa-orange text-glow-orange">SINCE APOLLO 17</span>
      </h2>
      <div class="separator-glow max-w-xs mx-auto my-4"></div>
      <p class="text-white/30 text-sm max-w-lg mx-auto">
        On December 19, 1972, the crew of Apollo 17 splashed down in the Pacific Ocean.
        No human has ventured beyond low-Earth orbit since. Until now.
      </p>
    </div>
  </GlowPanel>
</Layout>
