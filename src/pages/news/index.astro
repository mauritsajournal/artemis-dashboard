---
import Layout from '../../layouts/Layout.astro';
import GlowPanel from '../../components/GlowPanel.astro';
import SectionHeader from '../../components/SectionHeader.astro';

// Load news data
let news: any = { articles: [], fetchedAt: '' };
try {
  const mod = await import('../../../data/news.json');
  news = mod.default;
} catch { /* not available */ }

const articles = news.articles ?? [];

// Source colors
const sourceColors: Record<string, string> = {
  'NASA Artemis Blog': '#FC3D21',
  'NASA News': '#0B3D91',
  'SpaceNews': '#06B6D4',
  'NASASpaceflight': '#10B981',
  'Space.com': '#8B5CF6',
};

// Data age
let dataAge = '';
if (news.fetchedAt) {
  const diffMs = Date.now() - new Date(news.fetchedAt).getTime();
  const hours = Math.floor(diffMs / 3600000);
  const mins = Math.floor((diffMs % 3600000) / 60000);
  dataAge = hours > 0 ? `${hours}h ${mins}m ago` : `${mins}m ago`;
}

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffDays === 0) {
    const hours = Math.floor(diffMs / 3600000);
    if (hours === 0) return `${Math.floor(diffMs / 60000)}m ago`;
    return `${hours}h ago`;
  }
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout title="News — Artemis II">
  <div class="text-center mb-8 animate-fade-in-up">
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-wider text-white">
      MISSION <span class="text-mission-cyan text-glow-cyan">NEWS</span>
    </h1>
    <p class="text-white/30 text-sm mt-2 font-display tracking-wider">
      LATEST ARTEMIS COVERAGE FROM {Object.keys(sourceColors).length} SOURCES
    </p>
    {dataAge && (
      <div class="text-[10px] text-white/15 mt-1 font-display tracking-wider">
        Feed updated {dataAge}
      </div>
    )}
  </div>

  {articles.length > 0 ? (
    <div class="space-y-3">
      {articles.map((article: any, i: number) => {
        const color = sourceColors[article.source] ?? '#6B7280';
        return (
          <a href={article.link} target="_blank" rel="noopener"
             class:list={[
               'block glass-panel-sm p-4 sm:p-5 no-underline card-interactive animate-fade-in-up',
               `stagger-${Math.min(i + 1, 8)}`,
             ]}>
            <div class="flex flex-col sm:flex-row sm:items-start gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1.5">
                  <!-- Source badge -->
                  <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-display tracking-wider font-semibold"
                        style={`background: ${color}15; color: ${color}; border: 1px solid ${color}30`}>
                    <span class="w-1.5 h-1.5 rounded-full" style={`background: ${color}`}></span>
                    {article.source}
                  </span>
                  <span class="text-[10px] text-white/20 font-display tracking-wider">
                    {formatDate(article.pubDate)}
                  </span>
                </div>

                <h3 class="text-sm sm:text-base font-semibold text-white/80 group-hover:text-white mb-1 leading-snug">
                  {article.title}
                </h3>

                {article.description && (
                  <p class="text-xs text-white/25 leading-relaxed line-clamp-2">
                    {article.description}
                  </p>
                )}
              </div>

              <!-- External link icon -->
              <div class="shrink-0 self-center">
                <svg class="w-4 h-4 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  ) : (
    <GlowPanel class="text-center py-16 animate-fade-in-up">
      <div class="font-display text-white/20 tracking-widest text-sm mb-2">NO ARTICLES AVAILABLE</div>
      <p class="text-white/10 text-xs max-w-md mx-auto">
        News data has not been fetched yet. The automated pipeline will populate this feed with Artemis-related articles from NASA, SpaceNews, and other sources.
      </p>
    </GlowPanel>
  )}

  {articles.length > 0 && (
    <div class="text-center mt-8 text-[10px] text-white/10 font-display tracking-wider">
      {articles.length} ARTICLES FROM {[...new Set(articles.map((a: any) => a.source))].length} SOURCES
    </div>
  )}
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
